# ============================================================
# FinanceOS — Environment Variables Reference
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
BASE_PATH=/api
SESSION_SECRET=replace-with-a-long-random-secret

# ── Frontend ─────────────────────────────────────────────────
# Base URL for the Vite build. Set to /api for Replit reverse-proxy deployments.
# Leave unset (defaults to /) for local development.
# VITE_BASE_URL=/api

# ── Data Warehouse (SQL Server / Azure SQL) ──────────────────
# Set MSSQL_SERVER + MSSQL_DATABASE to activate SqlServerWarehouseAdapter.
# Ask AI introspects MSSQL_TABLES and uses live data to ground answers.
#
# Auth mode: MSSQL_AUTH_TYPE=windows (default) — NTLM with a domain service
# account. Works from Linux Docker/ECS containers pointing at an on-prem or
# EC2-hosted SQL Server that accepts Windows Authentication.
# Set MSSQL_AUTH_TYPE=sql to fall back to SQL Server authentication instead.
MSSQL_SERVER=sqlserver.corp.internal
MSSQL_DATABASE=FinanceDB
MSSQL_AUTH_TYPE=windows          # windows (default) | sql
MSSQL_DOMAIN=CORP                # Active Directory domain (required for windows auth)
MSSQL_USER=svc_financeos         # domain service account username
MSSQL_PASSWORD=
MSSQL_PORT=1433
MSSQL_SCHEMA=dbo
# Comma-separated list of tables to expose for NL→SQL generation (required for Ask AI grounding)
MSSQL_TABLES=FinancialTransactions,GLAccounts,BudgetActual,PremiumLedger,ClaimsRegister,RxDispensing
# MSSQL_ENCRYPT=true           # default true; set false for on-prem without TLS
# MSSQL_TRUST_CERT=false       # set true for self-signed certs in dev/test
# MSSQL_INSTANCE=              # Named SQL Server instance (e.g. SQLEXPRESS)

# ── Alternative: Snowflake ───────────────────────────────────
SNOWFLAKE_ACCOUNT=myaccount.us-east-1
SNOWFLAKE_USER=finance_svc
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=FINANCE_DW
SNOWFLAKE_WAREHOUSE=FINANCE_WH
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=FINANCE_ANALYST

# ── Alternative: BigQuery ────────────────────────────────────
BIGQUERY_PROJECT_ID=my-gcp-project
BIGQUERY_DATASET=finance
BIGQUERY_CREDENTIALS_JSON=  # Base64-encoded service account JSON

# ── LLM Provider ────────────────────────────────────────────
LLM_PROVIDER=openai          # openai | anthropic | azure_openai | bedrock
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Azure OpenAI (if LLM_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=https://myresource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Embedding Model ──────────────────────────────────────────
EMBEDDING_PROVIDER=openai    # openai | azure_openai | cohere | bedrock
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# ── Vector Database ──────────────────────────────────────────
VECTOR_DB_PROVIDER=pinecone  # pinecone | weaviate | qdrant | pgvector
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=financeos-docs

WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=financeos-docs

# ── Reranker ─────────────────────────────────────────────────
RERANK_PROVIDER=cohere       # cohere | voyageai | none
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-english-v3.0

# ── Authentication ───────────────────────────────────────────
AUTH_PROVIDER=clerk          # clerk | azure_ad | okta | auth0
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# Azure AD / Entra ID
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# Okta
OKTA_ISSUER=https://dev-xxxxx.okta.com/oauth2/default
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# ── Document Storage ─────────────────────────────────────────
STORAGE_PROVIDER=s3          # s3 | gcs | azure_blob | local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=financeos-documents

GCS_BUCKET=financeos-documents
GCS_CREDENTIALS_JSON=

# ── Eval & Observability ─────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

HELICONE_API_KEY=

# ── Feature Flags ────────────────────────────────────────────
ENABLE_AGENT_ORCHESTRATION=false
ENABLE_STREAMING=false
ENABLE_EVALS=true
MOCK_DATA=true               # When true, all repositories use in-memory fixtures
